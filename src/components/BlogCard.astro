---
export interface Props {
  title: string;
  date: string;
  description: string;
  category?: string;
  href?: string;
}
const { title, date, description, category = 'Perspective', href = '#' } =
  Astro.props;
---

<article class="blog-card reveal">
  <div class="blog-meta">
    <span class="blog-category">{category}</span>
    <time class="blog-date">{date}</time>
  </div>
  <h3 class="blog-title">
    <a href={href}>{title}</a>
  </h3>
  <p class="blog-desc">{description}</p>
  <a class="blog-readmore" href={href}>
    Read more <span class="arrow" aria-hidden="true">&rarr;</span>
  </a>
</article>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: clamp(1.5rem, 2.5vw, 2.1rem);
    height: 100%;
    transition: transform 0.3s var(--ease), border-color 0.3s var(--ease),
      box-shadow 0.3s var(--ease);
  }

  .blog-card:hover {
    transform: translateY(-4px);
    border-color: rgba(189, 135, 107, 0.5);
    box-shadow: 0 18px 40px -24px rgba(0, 20, 33, 0.35);
  }

  .blog-meta {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    font-family: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.78rem;
    font-weight: 600;
  }

  .blog-category {
    color: var(--clay);
  }

  .blog-date {
    color: rgba(0, 20, 33, 0.5);
  }

  .blog-title {
    font-size: 1.3rem;
    line-height: 1.25;
  }

  .blog-title a {
    color: var(--navy);
  }

  .blog-title a:hover {
    color: var(--clay);
  }

  .blog-desc {
    font-size: 1rem;
    line-height: 1.65;
    color: rgba(0, 20, 33, 0.66);
    margin: 0;
  }

  .blog-readmore {
    margin-top: auto;
    font-size: 0.94rem;
    font-weight: 500;
    color: var(--clay);
    display: inline-flex;
    gap: 0.4rem;
    align-items: center;
  }

  .blog-readmore .arrow {
    transition: transform 0.2s var(--ease);
  }

  .blog-readmore:hover .arrow {
    transform: translateX(3px);
  }
</style>
