---
import Layout from '../components/Layout.astro';
---

<Layout
  path="/platform"
  title="Platform | Altiplano Strategic Finance"
  description="The Altiplano intelligence platform: investor intelligence, market mapping, and competitive research for energy, climate, and deep tech founders and investors. In development."
>
  <!-- Page header -->
  <section class="section page-head">
    <div class="container">
      <span class="eyebrow">The Altiplano Platform</span>
      <h1>Investor and market intelligence for energy, climate, and deep tech</h1>
      <p class="lede">
        A working data layer built to answer the questions founders and
        investors ask about capital, markets, and competitive terrain.
      </p>
      <span class="status">
        <span class="status-dot" aria-hidden="true"></span>
        In development. Coming soon.
      </span>
    </div>
  </section>
</Layout>

<style>
  .page-head {
    padding-bottom: var(--section-y);
  }
  .page-head h1 {
    margin-block: 0.6rem 1rem;
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 1.5rem;
    font-family: var(--font-label);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--clay);
    background: rgba(189, 135, 107, 0.1);
    border: 1px solid rgba(189, 135, 107, 0.3);
    border-radius: 999px;
    padding: 0.5rem 1rem;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--clay);
    flex-shrink: 0;
  }
</style>
