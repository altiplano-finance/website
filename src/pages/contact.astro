---
import Layout from '../components/Layout.astro';
---

<Layout
  path="/contact"
  title="Contact | Altiplano Strategic Finance"
  description="Get in touch with Altiplano to discuss fundraising, financial modeling, and capital strategy for your startup in energy, climate, advanced materials, robotics, and space technologies."
>
  <section class="section contact">
    <div class="container contact-inner reveal">
      <span class="eyebrow">Contact</span>
      <h1>Let's talk strategy and capital.</h1>
      <p class="lede">
        Tell us about what you're building and where you are in the journey.
        Send a note and we'll get back to you to find a time to talk.
      </p>

      <a class="email-cta" href="mailto:hello@altiplano.finance">
        hello@altiplano.finance <span class="arrow" aria-hidden="true">&rarr;</span>
      </a>

      <div class="contact-detail">
        <span class="contact-label">Focus</span>
        <p>Energy · Climate · Advanced materials · Robotics · Space Tech</p>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-inner {
    max-width: 640px;
    margin-inline: 0;
  }

  .contact-inner h1 {
    margin-block: 0.6rem 1rem;
  }

  .email-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.75rem;
    font-size: clamp(1.25rem, 1.1rem + 0.8vw, 1.6rem);
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--navy);
    transition: color 0.2s var(--ease);
  }
  .email-cta:hover {
    color: var(--clay);
  }
  .email-cta .arrow {
    transition: transform 0.2s var(--ease);
  }
  .email-cta:hover .arrow {
    transform: translateX(4px);
  }

  .contact-detail {
    margin-top: 2.25rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
  }
  .contact-detail p {
    margin: 0;
  }

  .contact-label {
    display: block;
    font-family: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--clay);
    margin-bottom: 0.5rem;
  }
</style>
